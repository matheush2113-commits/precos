{
  "expo": {
    "name": "precoscertos",
    "slug": "preco",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/watermarked_img_9624452897969912344.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/watermarked_img_9624452897969912344.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "requireFullScreen": false,
      "bundleIdentifier": "com.seuusuario.geicordeiro"
    },
    "android": {
      "package": "com.seuusuario.geicordeiro",
      "versionCode": 6,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/watermarked_img_9624452897969912344.jpg",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/splash1.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O aplicativo precisa acessar a câmera para escanear os códigos de barras."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "73cce3af-c9c5-4521-9d91-c284184659df"
      }
    }
  }
}
