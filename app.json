{
  "expo": {
    "name": "PRECO",
    "slug": "gestao-estoque",
    "version": "5.0.1",
    "orientation": "portrait",
    "icon": "./assets/watermarked_img_9624452897969912344.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/watermarked_img_9624452897969912344.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "requireFullScreen": false,
      "bundleIdentifier": "com.seuusuario.geicordeiro"
    },
    "android": {
      "package": "com.seuusuario.geicordeiro",
      "versionCode": 7,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/watermarked_img_9624452897969912344.jpg",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/splash1.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "targetSdkVersion": 35,
            "compileSdkVersion": 36,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O aplicativo precisa acessar a câmera para escanear os códigos de barras."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O aplicativo precisa acessar suas fotos para você escolher a imagem do rótulo do produto.",
          "cameraPermission": "O aplicativo precisa acessar a câmera para tirar a foto do rótulo do produto.",
          "microphonePermission": false
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "O Preço Certo usa a câmera para ler o código de barras e o texto do rótulo do produto em tempo real.",
          "enableCodeScanner": true,
          "enableMicrophonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0a3a24b2-d850-425b-95ef-b2ec0cd317de"
      }
    }
  }
}
