{
  "expo": {
    "name": "precoscertos",
    "slug": "preco",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/watermarked_img_9624452897969912344.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/watermarked_img_9624452897969912344.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "requireFullScreen": false,
      "bundleIdentifier": "com.seuusuario.geicordeiro"
    },
    "android": {
      "package": "com.seuusuario.geicordeiro",
      "versionCode": 6,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/watermarked_img_9624452897969912344.jpg",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/splash1.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24
          }
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "devTeam": ""
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3794ad4e-d515-4ffd-a201-3a508cbe664e"
      },
      "oneSignalAppId": "ddbe0bb6-09cb-49f7-b408-59dedd8731ed"
    }
  }
}
